# QMT Bridge Windows environment file.
# Copy to qmt_bridge.env and edit values for your local QMT installation.

# HTTP bind address used by WSL Hermes.
QMT_BRIDGE_HOST=0.0.0.0
QMT_BRIDGE_PORT=8765

# xttrader configuration. Required for account/positions/orders/trades/place/cancel.
# Example: D:\YourBrokerQMT\userdata_mini
QMT_USERDATA_PATH=D:\国金证券QMT交易端\userdata
QMT_ACCOUNT_ID=8887010930
QMT_ACCOUNT_TYPE=STOCK
QMT_SESSION_ID=100

# Safety switch. Keep 0 until you are ready to allow real orders.
QMT_LIVE_TRADING_ENABLED=0

# Local audit output written by scripts\qmt_bridge.py.
QMT_BRIDGE_AUDIT_PATH=runtime\qmt_bridge_audit.jsonl
QMT_PYTHON_PATH=D:\国金证券QMT交易端\bin.x64\python.exe
QMT_CLIENT_MODE=research
QMT_XTDATA_PORT=58600
